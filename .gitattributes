# Auto detect text files and perform LF normalization
* text=auto

# Explicitly declare source code
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.md text eol=lf

# Images should use binary format
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg text eol=lf

# Lockfiles should use LF
*.lock text eol=lf
package-lock.json text eol=lf
bun.lock text eol=lf

# Web assembly files
*.wasm binary

# Shell scripts should use LF and be executable
*.sh text eol=lf
.husky/* text eol=lf

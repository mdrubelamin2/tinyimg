{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "tags": ["-lintignore"],
  "entry": [
    "src/lib/codecs/**/*.ts",
    "src/workers/**/*.ts",
    "scripts/*.mjs"
  ],
  "project": ["src/**/*.ts", "src/**/*.tsx", "scripts/**/*.mjs"],
  "ignoreDependencies": [
    "conventional-changelog-conventionalcommits",
    "tailwindcss"
  ],
  "rules": {
    "exports": "off",
    "types": "off"
  }
}

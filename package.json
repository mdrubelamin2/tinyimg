{
  "name": "TinyIMG",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test src/tests/e2e/basic.spec.ts",
    "test:e2e:benchmark": "playwright test src/tests/e2e/benchmarking.spec.ts",
    "test:quality": "node scripts/quality-gate.mjs test-images test-output && node scripts/quality-gate-svg.mjs test-images test-output",
    "test:full": "npm run test && npm run test:e2e && npm run test:quality",
    "prepare": "husky",
    "release": "semantic-release",
    "commitlint": "commitlint --from=HEAD~1 --to=HEAD --verbose"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@jsquash/avif": "^2.1.1",
    "@jsquash/jpeg": "^1.6.0",
    "@jsquash/jxl": "^1.3.0",
    "@jsquash/oxipng": "^2.3.0",
    "@jsquash/webp": "^1.5.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@resvg/resvg-wasm": "^2.6.2",
    "class-variance-authority": "^0.7.1",
    "fflate": "^0.8.2",
    "libimagequant-wasm": "^0.2.4",
    "pica": "^9.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "svgo": "^4.0.1",
    "svgtidy": "^0.1.4",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/bun": "^1.3.10",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^24.12.0",
    "@types/pica": "^9.0.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "conventional-changelog-conventionalcommits": "^9.3.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "lucide-react": "^0.577.0",
    "semantic-release": "^25.0.3",
    "sharp": "^0.33.5",
    "ssim.js": "^3.5.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0",
    "vitest": "^3.2.4"
  }
}
